/* Program to test person sets */

proc main () {
    set(set, personset())
    set(me, person(“@I1@“))
    addtoset(set, me, 0)
    showframe()
    set(set, union(set, parentset(set)))
    showframe()
    set(set, union(set, parentset(set)))
    showframe()
    set(set, union(set, parentset(set)))
    showframe()

    “NOW LET’S TRY KIDS—REMEMBER--CEDAR IS NOT IN THE DATABASE\n”

    clear(set)
    addtoset(set, me, 0)
    showframe()
    set(set, union(set, childset(set)))
    showframe()
    set(set, union(set, childset(set)))
    showframe()
    set(set, union(set, childset(set)))
    showframe()

    foreach(set, person, value, count) {
        d(count) ". " name(person) "\n"
    }
}
